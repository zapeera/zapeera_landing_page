# Zapeera marketing site — environment variables
# ----------------------------------------------------------------------
# Copy this file to .env.local for local development, and configure the
# same variables in your production hosting environment.

# WhatsApp number used by every conversion CTA on the site (FloatingCTA,
# pricing cards, hero, header link, footer link, contact page primary CTA,
# solutions pages). Format is permissive — pluses, spaces, and dashes are
# stripped before building the wa.me URL, so "+92 310 7100663" and
# "923107100663" both work.
NEXT_PUBLIC_WHATSAPP_NUMBER=+923107100663

# Gmail credentials used by /api/contact and /api/careers.
# Required only if the contact-form backend is in use.
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
# RECEIVER_EMAIL=
